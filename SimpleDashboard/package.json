{
  "name": "ea-dashboard-web",
  "version": "1.0.0",
  "description": "EA Smart Dashboard App",
  "author": "somkid2042-star",
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "web-push": "^3.6.7"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.eagrid.dashboard",
    "productName": "EA Smart Dashboard",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "server.js",
      "index.html",
      "style.css",
      "app.js",
      "manifest.json",
      "icon.png",
      "sw.js",
      "version.json"
    ]
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.8.3"
  }
}
