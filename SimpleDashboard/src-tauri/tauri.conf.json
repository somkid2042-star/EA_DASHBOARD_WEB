{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EA Smart Dashboard",
  "version": "1.1.2",
  "identifier": "com.eadashboard.app",
  "build": {
    "frontendDist": "../www",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "EA Smart Dashboard",
        "width": 1024,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' http://localhost:3000 https://xnwyrleniqxdxomjsopw.supabase.co https://*.supabase.co; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com;"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}